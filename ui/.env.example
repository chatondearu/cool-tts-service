# Session encryption key (min 32 chars) — auto-generated in dev if missing
NUXT_SESSION_PASSWORD=change-me-to-at-least-32-characters-long

# FastAPI backend URL (internal Docker network or localhost)
# Maps to runtimeConfig.apiBaseUrl
NUXT_API_BASE_URL=http://localhost:9000

# Optional Bearer token to authenticate against the FastAPI
# Maps to runtimeConfig.apiToken
NUXT_API_TOKEN=

# Admin credentials (env-based, no database)
# Maps to runtimeConfig.adminUser / runtimeConfig.adminPassword
NUXT_ADMIN_USER=admin
NUXT_ADMIN_PASSWORD=changeme
