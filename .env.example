# Docker Compose environment variables
# Copy to .env and fill in values before local compose (see docker-compose.local.yml).

# Session encryption key for the Nuxt UI (min 32 chars)
SERVICE_PASSWORD_SESSION=change-me-to-at-least-32-characters-long

# Admin credentials for the UI login
SERVICE_USER_ADMIN=admin
SERVICE_PASSWORD_ADMIN=changeme

# Optional: Bearer token to secure the FastAPI (shared between API and UI).
# Leave empty for no token, or set explicitly; Coolify can auto-fill via API_TOKEN.
SERVICE_BASE64_64_API_TOKEN=

# Host ports for local dev (Coolify ignores these; Traefik routes internally)
API_PORT=8000
UI_PORT=3000
