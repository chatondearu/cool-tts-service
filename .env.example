# Docker Compose environment variables
# Copy to .env and fill in values before local compose (see docker-compose.local.yml).

# On Coolify, the main docker-compose.yml falls back to generated SERVICE_* secrets
# (SERVICE_PASSWORD_64_TTS_SESSION, SERVICE_PASSWORD_64_TTS_ADMIN, SERVICE_BASE64_64_TTS_API)
# when these are unset—local override still requires explicit values below.

# Session encryption key for the Nuxt UI (min 32 chars)
NUXT_SESSION_PASSWORD=change-me-to-at-least-32-characters-long

# Admin credentials for the UI login
ADMIN_USER=admin
ADMIN_PASSWORD=changeme

# Optional: Bearer token to secure the FastAPI (shared between API and UI).
# Leave empty for no token, or set explicitly; Coolify can auto-fill via SERVICE_BASE64_64_TTS_API.
API_TOKEN=

# Host ports for local dev (Coolify ignores these; Traefik routes internally)
API_PORT=8000
UI_PORT=3000
